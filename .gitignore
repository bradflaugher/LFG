# LFG — root-level ignores. Android Gradle module has its own .gitignore.

# Logs / crashes.
*.log
hs_err_pid*
replay_pid*

# Kotlin / Gradle scratch.
.kotlin/

# IDE noise.
.idea/
*.iml
.DS_Store

# Do NOT ignore *.jar globally — gradle-wrapper.jar must be committed so CI can
# bootstrap Gradle without an extra setup step. Add narrower jar ignores below
# if you ever produce other jars.
